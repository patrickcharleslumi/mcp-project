# Luminance API Configuration
# The base URL of your Luminance instance (e.g., https://your-company.luminance.com)
LUMINANCE_BASE_URL=https://your-domain.example

# API Token (Bearer Token)
# This is a JWT bearer token used for API authentication.
# To get your token:
# 1. Log into Luminance UI
# 2. Go to Settings/API or Developer settings
# 3. Generate or copy your API token
# OR use your session token from browser DevTools (Network tab, look for Authorization header)
# Note: This is NOT a client secret - it's a bearer token used directly in Authorization header
LUMINANCE_API_TOKEN=your-bearer-token-here

# Server Configuration
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=60
TOOL_TIMEOUT_SECONDS=30

# MCP HTTP Wrapper Configuration
MCP_API_KEY=your-mcp-api-key
LUMINANCE_PROJECT_ID=1
MCP_REQUEST_TIMEOUT_SECONDS=30
MCP_MAX_CONCURRENCY=6
MCP_CACHE_TTL_SECONDS=300
MCP_CACHE_MAX_ENTRIES=2048
MCP_MAX_CLAUSES_PER_DOCUMENT=25
MCP_MAX_DOCUMENTS_SCAN=30
MCP_FEATURE_ENABLED=true
MCP_CIRCUIT_BREAKER_THRESHOLD=5
MCP_CIRCUIT_BREAKER_RESET_SECONDS=30
MCP_VERIFY_TLS=true
# MCP_TEMPLATE_CATALOG_PATH=./docs/template_catalog.json

# Feature Flags
ENABLE_SIGNING_LIKELIHOOD=true

# Prismatic Configuration (optional, for Prismatic-hosted deployment)
# When running in Prismatic, these may be automatically configured
# PRISMATIC_API_KEY=your-prismatic-api-key
# PRISMATIC_BASE_URL=https://app.prismatic.io
# PRISMATIC_REGION=us

# Salesforce MCP Configuration (optional, for company context enrichment)
# Enable Salesforce MCP integration for enhanced company context
# SALESFORCE_MCP_ENABLED=false
# SALESFORCE_MCP_ENDPOINT=http://localhost:3000  # Optional: custom endpoint

