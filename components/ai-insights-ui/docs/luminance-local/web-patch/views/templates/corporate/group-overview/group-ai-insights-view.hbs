                        <span class="thinking-label">Lumi is thinking</span>
                    </div>
                </div>
                <form class="agent-chat-input">
                    <input class="input-style agent-input" type="text" placeholder="Ask for Salesforce context (e.g., renewal risk, account history)"/>
                    <button class="primary send-agent-message" type="submit">Ask agent</button>
                </form>
            </div>
        </section>

    </div>
