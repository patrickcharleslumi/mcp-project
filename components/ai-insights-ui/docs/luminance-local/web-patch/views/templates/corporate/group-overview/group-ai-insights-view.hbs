<script id="tpl-group-ai-insights-view" type="text/html">
    <div class="group-ai-insights-view">
        <section class="ai-integrations-panel">
            <div class="label">
                <i class="fa fa-fw fa-plug"></i>
                Connected integrations
            </div>
            <div class="integration-list">
                <div class="integration-pill connected">
                    <div class="integration-logo salesforce">
                        <img src="{{asset '/icons/salesforce-logo.png'}}" alt="Salesforce"/>
                        <span class="fallback">SF</span>
                    </div>
                    <span class="name">Salesforce</span>
                    <i class="fa fa-fw fa-check-circle status-icon"></i>
                </div>
            </div>
        </section>

        <section class="ai-panel ai-summary-panel">
            <div class="header">
                <div class="title">
                    <i class="fa fa-fw fa-shield"></i>
                    AI matter summary
                </div>
                <div class="header-actions">
                    <span class="confidence-badge hidden">AI confidence</span>
                    <button class="tertiary toggle-reasoning">View reasoning</button>
                </div>
            </div>
            <div class="summary-grid">
                <div class="empty-state hidden">Summary will appear once analysis completes.</div>
            </div>
            <div class="summary-reasoning hidden"></div>
        </section>

        <section class="ai-panel ai-recommendations-panel">
            <div class="header">
                <div class="title">
                    <i class="fa fa-fw fa-bolt"></i>
                    Recommended actions
                </div>
                <button class="secondary approve-all hidden">Review & approve all</button>
            </div>
            <div class="recommendations-list">
                <div class="empty-state hidden">No recommendations at this time.</div>
            </div>
